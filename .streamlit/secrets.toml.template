# .streamlit/secrets.toml  —  PortfolioOptimizer secrets template
# ================================================================
# NEVER commit this file to git — it is already in .gitignore
# On Streamlit Community Cloud: paste these values into the
# Secrets UI (App → Settings → Secrets) instead.
#
# After filling in, rename to secrets.toml (remove .template).

# ── GitHub PAT (for auto-commit after trades / dividends) ────────────────────
[github]
pat      = "ghp_YOUR_TOKEN_HERE"
repo_url = "https://github.com/Blackl1stV35/PortfolioOptimizer"

# ── Groq LLM (free tier — get key at console.groq.com) ───────────────────────
[groq]
api_key = "gsk_YOUR_GROQ_KEY_HERE"

# ── Account PINs (4+ digits per account) ─────────────────────────────────────
# Key = account id from config/accounts.yaml
# Value = PIN string (will be checked on account switch)
# In dev mode (no pins set) any 4+ character string is accepted.
[account_pins]
"397543-7" = "YOUR_PIN_HERE"
# "new-account-002" = "ANOTHER_PIN"
